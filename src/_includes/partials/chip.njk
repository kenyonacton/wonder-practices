{% macro chip(flag) %}
{%- set labels = { "quiet": "Quiet", "active": "Active", "body-intense": "Intense", "tender": "Tender" } -%}
<span class="chip chip--{{ flag }}">
  {%- if flag == "quiet" -%}
    <svg class="chip__symbol" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="4" fill="currentColor"/></svg>
  {%- elif flag == "active" -%}
    <svg class="chip__symbol" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true"><path d="M3 14 Q 7 8, 11 14 T 19 14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" fill="none"/></svg>
  {%- elif flag == "body-intense" -%}
    <svg class="chip__symbol" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 21s-7-4.5-9-9c-1.5-3.5 1-7.5 4.5-7.5 1.8 0 3.3 0.9 4.5 2.5 1.2-1.6 2.7-2.5 4.5-2.5 3.5 0 6 4 4.5 7.5-2 4.5-9 9-9 9z" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linejoin="round"/></svg>
  {%- elif flag == "tender" -%}
    <svg class="chip__symbol" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="8.5" fill="none" stroke="currentColor" stroke-width="2"/></svg>
  {%- endif -%}
  <span class="chip__label">{{ labels[flag] }}</span>
</span>
{% endmacro %}
