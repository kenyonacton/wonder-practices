{%- set quietPractices = collections.practicesByFlag.quiet -%}
{%- set activePractices = collections.practicesByFlag.active -%}
{%- set bodyPractices = collections.practicesByFlag["body-intense"] -%}
{%- set tenderPractices = collections.practicesByFlag.tender -%}
{%- set labels = { "quiet": "Quiet", "active": "Active", "body-intense": "Body-intense", "tender": "Tender" } -%}
{%- set descriptions = {
  "quiet": "low intensity, no motion, a starting point",
  "active": "guided breath or movement; anyone can do these without modification",
  "body-intense": "strong physical sensation; review content notes before beginning",
  "tender": "may surface deeper feeling or body memory; approach slowly"
} -%}

{% macro scapeSymbol(flag) -%}
{%- if flag == "quiet" -%}
<svg width="15" height="15" viewBox="0 0 16 16" aria-hidden="true"><circle cx="8" cy="8" r="4.5" fill="#7DA0D0"/></svg>
{%- elif flag == "active" -%}
<svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true"><path d="M3 14 Q 7 8, 11 14 T 19 14" stroke="#5BC0A4" stroke-width="2.8" stroke-linecap="round" fill="none"/></svg>
{%- elif flag == "body-intense" -%}
<svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 21s-7-4.5-9-9c-1.5-3.5 1-7.5 4.5-7.5 1.8 0 3.3 0.9 4.5 2.5 1.2-1.6 2.7-2.5 4.5-2.5 3.5 0 6 4 4.5 7.5-2 4.5-9 9-9 9z" stroke="#9590C8" stroke-width="2" fill="none" stroke-linejoin="round"/></svg>
{%- elif flag == "tender" -%}
<svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><circle cx="8" cy="8" r="6" fill="none" stroke="#B7A7CB" stroke-width="2"/></svg>
{%- endif -%}
{%- endmacro %}

{% macro practiceList(practices) %}
<ul class="scape-practice-list">
  {% for p in practices %}
    <li class="scape-practice-list__item"><a href="{{ p.url | url }}">{{ p.data.title }}</a></li>
  {% endfor %}
</ul>
{% endmacro %}

{% macro routineList(routines) %}
<ul class="scape-practice-list scape-practice-list--routines">
  {% for r in routines %}
    <li class="scape-practice-list__item"><a href="{{ r.url | url }}">{{ r.data.title }}</a></li>
  {% endfor %}
</ul>
{% endmacro %}

{% macro categoryPanel(flag, practices, label, desc) %}
{%- set catRoutines = collections.routines | includesCategory(flag) -%}
<div class="scape-panel" data-panel="{{ flag }}" hidden>
  <header class="scape-panel-head">
    <h3 class="scape-panel-title">{{ scapeSymbol(flag) }} <span>{{ label }}</span></h3>
    <p class="scape-panel-desc">{{ desc }}</p>
  </header>
  {% if practices.length %}{{ practiceList(practices) }}{% else %}<p class="scape-panel-empty">No practices in this category yet.</p>{% endif %}
  {% if catRoutines.length %}
    <h4 class="scape-routines-head">Routines</h4>
    {{ routineList(catRoutines) }}
  {% endif %}
</div>
{% endmacro %}

<section class="scape-wrap" aria-labelledby="scape-heading">
  <h2 id="scape-heading" class="visually-hidden">Browse practices by category</h2>
  <p class="scape-intro"><em>click a mountain to explore that landscape</em></p>

  <svg class="scape-svg" viewBox="0 0 1000 330" preserveAspectRatio="xMidYMid meet">
    <g class="peak-group peak-quiet" data-category="quiet" role="button" tabindex="0" aria-label="Quiet practices">
      <path d="M 0,300 L 25,290 L 55,277 L 92,258 L 130,235 L 165,218 L 192,212 L 215,205 L 240,215 L 268,232 L 295,250 L 322,258 L 340,254 L 365,265 L 400,285 L 460,300 Z"/>
    </g>
    <g class="peak-group peak-active" data-category="active" role="button" tabindex="0" aria-label="Active practices">
      <path d="M 200,300 L 225,294 L 260,278 L 297,254 L 325,232 L 340,228 L 358,200 L 380,165 L 398,135 L 415,128 L 430,120 L 445,130 L 460,148 L 480,178 L 495,195 L 510,200 L 530,225 L 555,250 L 585,275 L 615,290 L 645,300 Z"/>
    </g>
    <g class="peak-group peak-body-intense" data-category="body-intense" role="button" tabindex="0" aria-label="Body-intense practices">
      <path d="M 390,300 L 425,278 L 462,250 L 495,222 L 525,202 L 542,196 L 555,200 L 565,203 L 575,188 L 588,165 L 595,155 L 600,148 L 608,156 L 618,168 L 628,172 L 638,165 L 650,178 L 668,200 L 695,228 L 730,260 L 770,287 L 810,300 Z"/>
    </g>
    <g class="peak-group peak-tender" data-category="tender" role="button" tabindex="0" aria-label="Tender practices">
      <path d="M 570,300 L 595,295 L 635,282 L 670,265 L 700,248 L 727,235 L 750,228 L 760,225 L 770,222 L 780,223 L 790,224 L 800,222 L 810,220 L 820,222 L 833,225 L 857,238 L 885,258 L 915,275 L 945,290 L 975,300 Z"/>
    </g>

    <foreignObject x="15" y="328" width="235" height="32" style="overflow:visible">
      <div xmlns="http://www.w3.org/1999/xhtml" class="cat-label" data-label="quiet">{{ scapeSymbol("quiet") }}<span>{{ labels["quiet"] }}</span></div>
    </foreignObject>
    <foreignObject x="265" y="328" width="235" height="32" style="overflow:visible">
      <div xmlns="http://www.w3.org/1999/xhtml" class="cat-label" data-label="active">{{ scapeSymbol("active") }}<span>{{ labels["active"] }}</span></div>
    </foreignObject>
    <foreignObject x="515" y="328" width="235" height="32" style="overflow:visible">
      <div xmlns="http://www.w3.org/1999/xhtml" class="cat-label" data-label="body-intense">{{ scapeSymbol("body-intense") }}<span>{{ labels["body-intense"] }}</span></div>
    </foreignObject>
    <foreignObject x="765" y="328" width="235" height="32" style="overflow:visible">
      <div xmlns="http://www.w3.org/1999/xhtml" class="cat-label" data-label="tender">{{ scapeSymbol("tender") }}<span>{{ labels["tender"] }}</span></div>
    </foreignObject>
  </svg>

  <div class="scape-mobile-nav" aria-label="Category navigation, mobile">
    <button type="button" class="scape-mobile-btn" data-category="quiet" aria-label="Quiet practices">{{ scapeSymbol("quiet") }}<span>Quiet</span></button>
    <button type="button" class="scape-mobile-btn" data-category="active" aria-label="Active practices">{{ scapeSymbol("active") }}<span>Active</span></button>
    <button type="button" class="scape-mobile-btn" data-category="body-intense" aria-label="Body-intense practices">{{ scapeSymbol("body-intense") }}<span>Body</span></button>
    <button type="button" class="scape-mobile-btn" data-category="tender" aria-label="Tender practices">{{ scapeSymbol("tender") }}<span>Tender</span></button>
  </div>

  <div class="scape-panel-wrap" aria-live="polite">
    <div class="scape-panel scape-panel--all" data-panel="all">
      <header class="scape-panel-head">
        <h3 class="scape-panel-title">All practices</h3>
        <p class="scape-panel-desc">browsing every category</p>
      </header>
      {% if quietPractices.length or activePractices.length or bodyPractices.length or tenderPractices.length %}
        {% if quietPractices.length %}
          <section class="scape-panel-group">
            <h4 class="scape-panel-group-head">{{ scapeSymbol("quiet") }} <span>{{ labels["quiet"] }}</span></h4>
            {{ practiceList(quietPractices) }}
          </section>
        {% endif %}
        {% if activePractices.length %}
          <section class="scape-panel-group">
            <h4 class="scape-panel-group-head">{{ scapeSymbol("active") }} <span>{{ labels["active"] }}</span></h4>
            {{ practiceList(activePractices) }}
          </section>
        {% endif %}
        {% if bodyPractices.length %}
          <section class="scape-panel-group">
            <h4 class="scape-panel-group-head">{{ scapeSymbol("body-intense") }} <span>{{ labels["body-intense"] }}</span></h4>
            {{ practiceList(bodyPractices) }}
          </section>
        {% endif %}
        {% if tenderPractices.length %}
          <section class="scape-panel-group">
            <h4 class="scape-panel-group-head">{{ scapeSymbol("tender") }} <span>{{ labels["tender"] }}</span></h4>
            {{ practiceList(tenderPractices) }}
          </section>
        {% endif %}
      {% else %}
        <p class="scape-panel-empty">No practices yet.</p>
      {% endif %}
      {% if collections.routines.length %}
        <section class="scape-panel-group">
          <h4 class="scape-panel-group-head">Routines</h4>
          {{ routineList(collections.routines) }}
        </section>
      {% endif %}
    </div>

    {{ categoryPanel("quiet", quietPractices, labels["quiet"], descriptions["quiet"]) }}
    {{ categoryPanel("active", activePractices, labels["active"], descriptions["active"]) }}
    {{ categoryPanel("body-intense", bodyPractices, labels["body-intense"], descriptions["body-intense"]) }}
    {{ categoryPanel("tender", tenderPractices, labels["tender"], descriptions["tender"]) }}
  </div>

  <link rel="stylesheet" href="{{ '/assets/css/mountain-scape.css' | url }}">
  <script type="module" src="{{ '/assets/js/mountain-scape.js' | url }}"></script>
</section>
